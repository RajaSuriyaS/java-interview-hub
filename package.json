{
  "name": "java-interview-hub",
  "version": "1.0.0",
  "description": "Senior Java Backend Interview Study Hub",
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env --disable-warning=ExperimentalWarning server.js",
    "dev": "nodemon --exec \"node --env-file-if-exists=.env --disable-warning=ExperimentalWarning\" server.js",
    "build:css": "tailwindcss -c tailwind.config.js -i ./src/tailwind.css -o ./public/css/tailwind.css --minify"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "tailwindcss": "^3.4.19"
  }
}
