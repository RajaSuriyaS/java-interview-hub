# ============================================================
#  Java Interview Hub — deployment environment
#  Copy to deploy/.env on the VPS and fill in. NEVER commit .env.
# ============================================================

# --- Domain (DuckDNS) ---------------------------------------
# Full domain Caddy serves HTTPS for
DOMAIN=javazerotoall.duckdns.org

# --- DuckDNS updater ----------------------------------------
# SUBDOMAINS = just the label(s), comma-separated, WITHOUT ".duckdns.org"
# e.g. for javazerotoall.duckdns.org -> javazerotoall
DUCKDNS_SUBDOMAINS=javazerotoall
# Your DuckDNS token from https://www.duckdns.org (Account page)
DUCKDNS_TOKEN=your-duckdns-token-here

# --- Code execution provider --------------------------------
# wandbox = free public API (default, zero infra, Java + Python)
# piston  = self-hosted Piston (also runs Bash); set PISTON_URL accordingly
EXEC_PROVIDER=wandbox
PISTON_URL=http://piston:2000

# --- Google sign-in + cloud progress sync (OPTIONAL) --------
# Leave GOOGLE_CLIENT_ID blank to run in localStorage-only mode (no accounts).
# Create credentials at https://console.cloud.google.com/apis/credentials
#   -> Create OAuth client ID -> Web application
#   Authorised redirect URI:  https://<DOMAIN>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Only set if the auto-derived callback URL is wrong for your proxy setup:
# GOOGLE_CALLBACK_URL=https://javazerotoall.duckdns.org/auth/google/callback
# Long random string that signs session cookies (REQUIRED for stable logins).
# Generate with:  openssl rand -hex 32
SESSION_SECRET=

# Make Google sign-in MANDATORY (full login wall). true = must sign in to use the app.
REQUIRE_AUTH=true

# --- Admin console (approve/reject users; grant/revoke premium) ---------
# Comma-separated admin emails. Defaults to the site owner if unset.
ADMIN_EMAILS=rajasuriyas@gmail.com

# --- Monetization / paywall (ON by default) ----------------------------
# FREE users receive only the free-tier modules; premium modules are locked
# stubs (body stripped server-side). This is ON by default now — set it to
# off/false/0 to open the whole site to every signed-in user. Pair with
# REQUIRE_AUTH=true so content can't be scraped without signing in.
MONETIZATION=on
# Override the free-tier modules (comma-separated ids). Default policy = all of
# Phase 0 plus the first module of every other phase.
# FREE_MODULE_IDS=
# Price labels shown on the paywall (display only; real amounts come from the
# Stripe Price / Razorpay Plan configured below).
PRICE_MONTHLY_LABEL=₹499
PRICE_YEARLY_LABEL=₹3,999

# --- Payments: Stripe (OPTIONAL) ---------------------------------------
# Dashboard -> Developers -> API keys (use test keys first). Create two
# recurring Prices (monthly, yearly) and paste their price_... ids.
# Add a webhook endpoint https://<DOMAIN>/api/billing/webhook/stripe for events
# checkout.session.completed, customer.subscription.updated|deleted; paste its
# signing secret (whsec_...).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# --- Payments: Razorpay (OPTIONAL) -------------------------------------
# Dashboard -> Settings -> API Keys. Create two Subscription Plans
# (monthly, yearly) and paste their plan_... ids. Add a webhook
# https://<DOMAIN>/api/billing/webhook/razorpay for subscription.activated,
# subscription.charged, subscription.cancelled; paste its secret.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_MONTHLY=
RAZORPAY_PLAN_YEARLY=
