# ============================================================
#  Java Interview Hub — deployment environment
#  Copy to deploy/.env on the VPS and fill in. NEVER commit .env.
# ============================================================

# --- Domain (DuckDNS) ---------------------------------------
# Full domain Caddy serves HTTPS for
DOMAIN=javazerotoall.duckdns.org

# --- DuckDNS updater ----------------------------------------
# SUBDOMAINS = just the label(s), comma-separated, WITHOUT ".duckdns.org"
# e.g. for javazerotoall.duckdns.org -> javazerotoall
DUCKDNS_SUBDOMAINS=javazerotoall
# Your DuckDNS token from https://www.duckdns.org (Account page)
DUCKDNS_TOKEN=your-duckdns-token-here

# --- Code execution provider --------------------------------
# wandbox = free public API (default, zero infra, Java + Python)
# piston  = self-hosted Piston (also runs Bash); set PISTON_URL accordingly
EXEC_PROVIDER=wandbox
PISTON_URL=http://piston:2000

# --- Google sign-in + cloud progress sync (OPTIONAL) --------
# Leave GOOGLE_CLIENT_ID blank to run in localStorage-only mode (no accounts).
# Create credentials at https://console.cloud.google.com/apis/credentials
#   -> Create OAuth client ID -> Web application
#   Authorised redirect URI:  https://<DOMAIN>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Only set if the auto-derived callback URL is wrong for your proxy setup:
# GOOGLE_CALLBACK_URL=https://javazerotoall.duckdns.org/auth/google/callback
# Long random string that signs session cookies (REQUIRED for stable logins).
# Generate with:  openssl rand -hex 32
SESSION_SECRET=
