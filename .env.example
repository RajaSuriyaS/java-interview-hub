# ============================================================
#  Local development environment.
#  Copy to ".env" (which is git-ignored) and fill in your values:
#      cp .env.example .env
#  Then `npm start` picks it up automatically (Node --env-file).
#  For VPS/Docker, use deploy/.env instead (see docs/VPS_DEPLOY.md).
# ============================================================

PORT=3030

# --- Google sign-in (OPTIONAL) ------------------------------
# Leave blank to run in localStorage-only mode (no accounts).
# Get these from https://console.cloud.google.com/apis/credentials
#   Create credentials -> OAuth client ID -> Web application
# For LOCAL testing, add this Authorised redirect URI in Google:
#   http://localhost:3030/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Signs the session cookie. Generate one with:  openssl rand -hex 32
SESSION_SECRET=

# Optional — only if the auto-derived callback URL is wrong:
# GOOGLE_CALLBACK_URL=http://localhost:3030/auth/google/callback

# Where the SQLite progress DB is written (default ./data):
# DATA_DIR=./data

# Make Google sign-in MANDATORY (full login wall). true = must sign in to use the app.
REQUIRE_AUTH=true
